<?xml version="1.0" encoding="UTF-8"?>
<!DOCTYPE plist PUBLIC "-//Apple//DTD PLIST 1.0//EN" "http://www.apple.com/DTDs/PropertyList-1.0.dtd">
<plist version="1.0">
  <dict>
    <key>Label</key>
    <string>com.vibeblock.daemon</string>

    <key>ProgramArguments</key>
    <array>
      <string>/usr/local/bin/vibeblock</string>
      <string>daemon</string>
      <string>--interval</string>
      <string>60s</string>
    </array>

    <key>RunAtLoad</key>
    <true/>

    <key>KeepAlive</key>
    <true/>

    <key>StandardOutPath</key>
    <string>/tmp/vibeblock-daemon.out.log</string>

    <key>StandardErrorPath</key>
    <string>/tmp/vibeblock-daemon.err.log</string>
  </dict>
</plist>
