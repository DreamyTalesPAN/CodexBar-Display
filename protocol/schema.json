{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://codexbar-display.dev/schema/frame-v1.json",
  "title": "codexbar-display frame v1",
  "type": "object",
  "required": ["v"],
  "properties": {
    "v": {
      "const": 1
    },
    "provider": {
      "type": "string",
      "minLength": 1
    },
    "label": {
      "type": "string",
      "minLength": 1
    },
    "session": {
      "type": "integer",
      "minimum": 0,
      "maximum": 100
    },
    "weekly": {
      "type": "integer",
      "minimum": 0,
      "maximum": 100
    },
    "resetSecs": {
      "type": "integer",
      "minimum": 0
    },
    "usageMode": {
      "type": "string",
      "enum": ["used", "remaining"]
    },
    "sessionTokens": {
      "type": "integer",
      "minimum": 0
    },
    "weekTokens": {
      "type": "integer",
      "minimum": 0
    },
    "totalTokens": {
      "type": "integer",
      "minimum": 0
    },
    "theme": {
      "type": "string",
      "enum": ["classic", "crt", "mini"]
    },
    "error": {
      "type": "string",
      "minLength": 1
    }
  },
  "additionalProperties": true
}
